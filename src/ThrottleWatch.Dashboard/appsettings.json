{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.SignalR": "Information"
    }
  },
  "AllowedHosts": "*",
  "ThrottleWatch": {
    "ApiBaseUrl": "http://localhost:5000",
    "HubUrl": "http://localhost:5000/hubs/throttle",
    "RefreshIntervalSeconds": 5,
    "MaxDataPoints": 60
  }
}

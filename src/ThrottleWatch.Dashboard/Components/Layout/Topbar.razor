@inject IThemeService ThemeService
@inject IMetricsService MetricsService
@inject IOptions<ThrottleWatchOptions> Options
@using Microsoft.Extensions.Options
@using ThrottleWatch.Dashboard.Models
@implements IAsyncDisposable

<header class="topbar @(_sidebarCollapsed ? "topbar--collapsed" : "")"
        role="banner"
        aria-label="Barra superior">

    <div class="topbar__breadcrumb" aria-label="Navegação">
        <span class="topbar__breadcrumb-item">ThrottleWatch</span>
        @if (!string.IsNullOrEmpty(PageTitle))
        {
            <span class="topbar__breadcrumb-sep" aria-hidden="true">/</span>
            <span class="topbar__breadcrumb-item topbar__breadcrumb-item--active"
                  aria-current="page">@PageTitle</span>
        }
    </div>

    <div class="topbar__actions" role="toolbar" aria-label="Ações da barra superior">
        <div class="connection-indicator connection-indicator--@_connectionState.ToString().ToLowerInvariant()"
             aria-label="Status da API: @_connectionState"
             role="status"
             aria-live="polite">
            <div class="connection-indicator__dot" aria-hidden="true"></div>
            <span class="topbar__connection-label">@GetConnectionLabel()</span>
        </div>

        <div class="divider" style="width: 1px; height: 20px; margin: 0; background: var(--tw-surface-border);"></div>

        <button class="btn btn--ghost btn--icon"
                @onclick="ToggleTheme"
                aria-label="@(ThemeService.IsDarkMode ? "Mudar para modo claro" : "Mudar para modo escuro")"
                title="@(ThemeService.IsDarkMode ? "Modo claro" : "Modo escuro")">
            @if (ThemeService.IsDarkMode)
            {
                <Icon Name="sun" Size="lg" />
            }
            else
            {
                <Icon Name="moon" Size="lg" />
            }
        </button>
    </div>
</header>

@code {
    [Parameter] public string? PageTitle { get; set; }
    [Parameter] public bool SidebarCollapsed { get; set; }

    private ConnectionState _connectionState = ConnectionState.Connecting;
    private bool _sidebarCollapsed;
    private readonly CancellationTokenSource _cts = new();

    protected override void OnParametersSet()
    {
        _sidebarCollapsed = SidebarCollapsed;
    }

    protected override async Task OnInitializedAsync()
    {
        ThemeService.ThemeChanged += OnThemeChanged;
        await RefreshApiStatusAsync();
        _ = PollApiStatusAsync(_cts.Token);
    }

    private async Task PollApiStatusAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(Options.Value.RefreshIntervalSeconds));

        while (await timer.WaitForNextTickAsync(ct))
        {
            await RefreshApiStatusAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshApiStatusAsync()
    {
        try
        {
            var health = await MetricsService.GetHealthAsync(_cts.Token);
            _connectionState = health is not null
                ? ConnectionState.Connected
                : ConnectionState.Failed;
        }
        catch (OperationCanceledException)
        {
        }
        catch
        {
            _connectionState = ConnectionState.Failed;
        }
    }

    private void ToggleTheme()
    {
        ThemeService.ToggleTheme();
    }

    private void OnThemeChanged(object? sender, EventArgs e) =>
        InvokeAsync(StateHasChanged);

    private string GetConnectionLabel() => _connectionState switch
    {
        ConnectionState.Connected => "API online",
        ConnectionState.Connecting => "Verificando",
        ConnectionState.Failed => "API offline",
        _ => "Offline"
    };

    public async ValueTask DisposeAsync()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
        await _cts.CancelAsync();
        _cts.Dispose();
    }
}
